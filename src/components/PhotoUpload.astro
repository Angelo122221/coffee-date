---

<label class="card" style="display:grid; gap:16px; padding:18px; border-style:dashed;">
  <span class="muted">Upload your cutest photo 📸</span>
  <input
    name="photo"
    type="file"
    accept="image/png,image/jpeg,image/webp"
    data-photo-input
    style="padding: 8px 0;"
  />
  <img
    data-photo-preview
    alt="Photo preview"
    class="hero-image hidden"
    style="aspect-ratio: 4 / 5; object-fit: cover;"
  />
  <p class="muted" style="margin: 0;">PNG, JPG, or WEBP. Max 10 MB.</p>
</label>

