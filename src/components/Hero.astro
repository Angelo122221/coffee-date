---
interface Props {
  headline: string;
  body: string;
  ctaHref: string;
  ctaLabel?: string;
}

const { headline, body, ctaHref, ctaLabel = 'Continue' } = Astro.props as Props;
---

<section class="container" style="padding: 48px 0 24px;">
  <div class="card card-pad" style="display:grid; gap:24px; text-align:center;">
    <img
      class="hero-image hero-image-compact float"
      src="https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExd2c0eTQ5YzI4NnVhMnh3N2E4cXV2Y2Yzb3d6eWJ6eGxqYjQ2eXJvbiZlcD12MV9naWZzX3NlYXJjaCZjdD1n/3oriO0OEd9QIDdllqo/giphy.gif"
      alt="Cute coffee themed animation"
    />
    <div class="stack" style="gap:10px; place-items:center;">
      <span class="eyebrow">☕ Coffee date</span>
      <h1 class="title">{headline}</h1>
      <p class="subtitle" style="max-width: 560px; margin: 0 auto;">{body}</p>
    </div>
    <div>
      <a class="button button-primary" href={ctaHref}>{ctaLabel} <span aria-hidden="true">→</span></a>
    </div>
  </div>
</section>
