---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props as Props;
---

<section class="card card-pad" style="max-width: 600px; width: 100%; margin: 0 auto;">
  <div class="stack">
    <slot name="media" />
    <div class="stack" style="gap:8px;">
      <h2 class="title" style="font-size: clamp(1.8rem, 4vw, 2.8rem);">{title}</h2>
      {description && <p class="subtitle" style="margin: 0;">{description}</p>}
    </div>
    <slot />
  </div>
</section>

