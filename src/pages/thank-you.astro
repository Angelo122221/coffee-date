---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Thank You" description="A sweet closing page for the coffee date invitation.">
  <main class="page-shell">
    <section class="container">
      <div class="card card-pad" style="text-align:center; display:grid; gap:18px; place-items:center;">
        <span class="eyebrow">💌 Submission received</span>
        <h1 class="title">Thank you for saying yes to the vibe.</h1>
        <p class="subtitle" style="max-width: 560px;">I’m really glad you’re here. This tiny website was made with a lot of care, and I hope it made you smile a little.</p>
        <a class="button button-primary" href="/">Back to start</a>
      </div>
    </section>
  </main>
</MainLayout>

