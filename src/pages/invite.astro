---
import MainLayout from '../layouts/MainLayout.astro';
import ProgressBar from '../components/ProgressBar.astro';
import QuestionCard from '../components/QuestionCard.astro';
import CoffeeOptions from '../components/CoffeeOptions.astro';
import AvailabilityPicker from '../components/AvailabilityPicker.astro';
import PhotoUpload from '../components/PhotoUpload.astro';

const positiveGif = `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(`
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 220">
    <defs>
      <linearGradient id="g" x1="0" x2="1">
        <stop offset="0%" stop-color="#fff8f2"/>
        <stop offset="100%" stop-color="#fff1e6"/>
      </linearGradient>
    </defs>
    <rect width="320" height="220" rx="28" fill="url(#g)"/>
    <g transform="translate(100 70)">
      <rect x="18" y="28" width="76" height="56" rx="16" fill="#d97757"/>
      <rect x="0" y="36" width="24" height="40" rx="12" fill="#f5b89f"/>
      <path d="M22 20c10-22 26-22 36 0" fill="none" stroke="#eab308" stroke-width="6" stroke-linecap="round">
        <animateTransform attributeName="transform" type="translate" values="0 0;0 -6;0 0" dur="2.8s" repeatCount="indefinite"/>
      </path>
      <circle cx="32" cy="52" r="5" fill="#fff"/>
      <circle cx="58" cy="52" r="5" fill="#fff"/>
      <path d="M38 66c6 6 18 6 24 0" fill="none" stroke="#fff" stroke-width="4" stroke-linecap="round"/>
    </g>
    <g fill="#d97757">
      <path d="M250 55c5 0 9 4 9 9 0 8-9 14-9 14s-9-6-9-14c0-5 4-9 9-9z">
        <animate attributeName="opacity" values="0.25;1;0.25" dur="2.4s" repeatCount="indefinite"/>
      </path>
      <path d="M260 78c4 0 7 3 7 7 0 6-7 11-7 11s-7-5-7-11c0-4 3-7 7-7z">
        <animate attributeName="opacity" values="1;0.35;1" dur="2.1s" repeatCount="indefinite"/>
      </path>
    </g>
  </svg>
`)}`;

const worriedGif = `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(`
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 220">
    <defs>
      <linearGradient id="g2" x1="0" x2="1">
        <stop offset="0%" stop-color="#fff8f2"/>
        <stop offset="100%" stop-color="#fde7dc"/>
      </linearGradient>
    </defs>
    <rect width="320" height="220" rx="28" fill="url(#g2)"/>
    <g transform="translate(96 72)">
      <rect x="18" y="28" width="76" height="56" rx="16" fill="#eab308"/>
      <rect x="0" y="36" width="24" height="40" rx="12" fill="#f5b89f"/>
      <circle cx="32" cy="52" r="5" fill="#2d2d2d"/>
      <circle cx="58" cy="52" r="5" fill="#2d2d2d"/>
      <path d="M37 69c6-5 18-5 24 0" fill="none" stroke="#2d2d2d" stroke-width="4" stroke-linecap="round"/>
      <animateTransform attributeName="transform" type="translate" values="0 0;2 0;-2 0;0 0" dur="0.5s" repeatCount="indefinite"/>
    </g>
    <text x="200" y="68" font-family="Inter, Arial, sans-serif" font-size="22" fill="#d97757">are you sure?</text>
  </svg>
`)}`;
---

<MainLayout title="Coffee Date Questions" description="Answer a few soft questions and share your coffee date preferences.">
  <main class="page-shell">
    <form class="container stack" action="/api/submit" method="post" enctype="multipart/form-data" data-submit-form>
      <input type="hidden" name="answer" data-field="answer" />
      <input type="hidden" name="coffee_date_type" data-field="coffee_date_type" />
      <input type="hidden" name="my_selected_date" data-field="my_selected_date" />

      <ProgressBar current={1} total={5} />

      <QuestionCard title="Would you like to go on a coffee date with me?">
        <div slot="media" class="stack" style="gap:12px; place-items:center;">
          <img
            src={positiveGif}
            alt="Cute coffee animation"
            class="hero-image gif-compact"
            data-invite-visual
          />
        </div>
        <div class="pill-row" style="justify-content:center;">
          <button class="button button-primary" type="button" data-yes-button>Yes</button>
          <span class="playful-stage" aria-label="No button area">
            <button class="button button-secondary playful-no" type="button" data-no-button>
              <span data-no-label>No</span>
            </button>
          </span>
        </div>
      </QuestionCard>

      <section class="card card-pad hidden" data-followup>
        <div class="stack" style="gap:16px;">
          <h2 class="title" style="font-size: clamp(1.8rem, 4vw, 2.8rem);">Are you sure? 🥺</h2>
          <p class="subtitle" style="margin: 0;">I had to ask one more time.</p>
          <div class="pill-row">
            <button class="button button-primary" type="button" data-final-answer="yes">Yes, I’m sure</button>
            <button class="button button-secondary" type="button" data-final-answer="no">Let me think again</button>
          </div>
        </div>
      </section>

      <section class="card card-pad hidden" data-step="2">
        <div class="stack" style="gap:16px;">
          <h2 class="title" style="font-size: clamp(1.8rem, 4vw, 2.8rem);">What kind of coffee date would you enjoy?</h2>
          <CoffeeOptions />
          <label class="stack hidden" style="gap:8px;" data-custom-wrap>
            <span class="muted">Custom coffee date</span>
            <input
              name="custom_coffee_type"
              type="text"
              placeholder="Tell me your perfect date idea"
              class="card"
              style="padding: 14px 16px; border: 0;"
            />
          </label>
          <div class="pill-row hidden" data-custom-continue>
            <button class="button button-primary" type="button" data-custom-done>Continue</button>
          </div>
        </div>
      </section>

      <section class="card card-pad hidden" data-step="3">
        <div class="stack" style="gap:16px;">
          <h2 class="title" style="font-size: clamp(1.8rem, 4vw, 2.8rem);">When are you available?</h2>
          <AvailabilityPicker />
        </div>
      </section>

      <section class="card card-pad hidden" data-step="4">
        <div class="stack" style="gap:16px;">
          <h2 class="title" style="font-size: clamp(1.8rem, 4vw, 2.8rem);">Upload your cutest photo 📸</h2>
          <PhotoUpload />
        </div>
      </section>

      <section class="card card-pad hidden" data-step="5">
        <div class="stack" style="gap:18px;">
          <h2 class="title" style="font-size: clamp(1.8rem, 4vw, 2.8rem);">Thank you for answering ❤️</h2>
          <div class="card" style="padding: 18px; background: rgba(255,255,255,0.7);">
            <pre data-summary style="margin: 0; white-space: pre-wrap; font-family: Inter, sans-serif;"></pre>
          </div>
          <button class="button button-primary" type="submit">Submit</button>
        </div>
      </section>
    </form>
  </main>

  <script is:inline>
    const state = {
      answer: '',
      coffee_date_type: '',
      custom_coffee_type: '',
      her_available_date: '',
      her_available_time: '',
      my_selected_date: '',
      photo_url: ''
    };
    const totalSteps = 5;
    const progressLabel = document.querySelector('[data-progress-label]');
    const progressPercent = document.querySelector('[data-progress-percent]');
    const progressFill = document.querySelector('[data-progress-fill]');
    const inviteVisual = document.querySelector('[data-invite-visual]');
    const noButton = document.querySelector('[data-no-button]');
    const noLabel = document.querySelector('[data-no-label]');
    const yesButton = document.querySelector('[data-yes-button]');
    let noDodges = 0;

    const setProgress = (stepNumber) => {
      const percentage = Math.min(100, Math.max(0, (stepNumber / totalSteps) * 100));
      if (progressLabel) {
        progressLabel.textContent = `Step ${stepNumber} of ${totalSteps}`;
      }
      if (progressPercent) {
        progressPercent.textContent = `${Math.round(percentage)}%`;
      }
      if (progressFill) {
        progressFill.style.width = `${percentage}%`;
      }
    };

    const setWorriedMode = () => {
      if (inviteVisual) {
        inviteVisual.src = worriedGif;
      }
      if (noLabel) {
        noLabel.textContent = 'are you sure?';
      }
    };

    const resetNoButton = () => {
      if (noButton) {
        noButton.style.transform = '';
        noButton.textContent = '';
        noButton.innerHTML = '<span data-no-label>No</span>';
      }
      if (yesButton) {
        yesButton.style.transform = '';
      }
    };

    const dodgeNoButton = () => {
      if (!noButton) {
        return;
      }

      noDodges += 1;
      setWorriedMode();

      const direction = noDodges % 2 === 0 ? 1 : -1;
      const horizontal = 28 + Math.random() * 32;
      const vertical = 6 + Math.random() * 18;
      const rotate = noDodges > 2 ? (direction * 5) : (direction * 2);

      noButton.style.transform = `translate(${direction * horizontal}px, ${-vertical}px) rotate(${rotate}deg)`;

      if (noDodges > 2) {
        noButton.textContent = 'are you sure?';
      }
      if (yesButton && noDodges > 3) {
        yesButton.style.transform = 'scale(1.02)';
      }
    };

    const handleYes = () => {
      state.answer = 'yes';
      if (inviteVisual) {
        inviteVisual.src = positiveGif;
      }
      resetNoButton();
      showStep(2);
      document.querySelector('[data-step="2"]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      syncSummary();
    };

    const handleNo = (event) => {
      event?.preventDefault?.();
      dodgeNoButton();
    };

    const showStep = (stepNumber) => {
      document.querySelectorAll('[data-step]').forEach((section) => {
        section.classList.toggle('hidden', Number(section.dataset.step) !== stepNumber);
      });
      const followup = document.querySelector('[data-followup]');
      if (followup) {
        followup.classList.toggle('hidden', stepNumber !== 1 || state.answer !== 'no');
      }
      setProgress(stepNumber);
    };

    const syncSummary = () => {
      const summary = [
        `Answer: ${state.answer || '—'}`,
        `Coffee date type: ${state.coffee_date_type || '—'}`,
        state.custom_coffee_type ? `Custom idea: ${state.custom_coffee_type}` : null,
        `Her available date: ${state.her_available_date || '—'}`,
        `Her available time: ${state.her_available_time || '—'}`,
        `My selected date: ${state.my_selected_date || '—'}`,
        `Photo: ${state.photo_url ? 'Ready' : 'Not uploaded yet'}`
      ].filter(Boolean).join('\n');

      const summaryElement = document.querySelector('[data-summary]');
      if (summaryElement) {
        summaryElement.textContent = summary;
      }

      document.querySelectorAll('[data-field]').forEach((field) => {
        field.value = state[field.dataset.field] || '';
      });
    };

    yesButton?.addEventListener('click', (event) => {
      event.preventDefault();
      handleYes();
    });

    noButton?.addEventListener('pointerenter', dodgeNoButton);
    noButton?.addEventListener('click', handleNo);

    document.querySelectorAll('[data-final-answer]').forEach((button) => {
      button.addEventListener('click', () => {
        state.answer = button.dataset.finalAnswer;
        if (state.answer === 'yes') {
          handleYes();
        } else {
          if (inviteVisual) {
            inviteVisual.src = worriedGif;
          }
          showStep(5);
        }
      });
    });

    document.querySelectorAll('[data-option]').forEach((button) => {
      button.addEventListener('click', () => {
        state.coffee_date_type = button.dataset.option;
        const customWrap = document.querySelector('[data-custom-wrap]');
        const customContinue = document.querySelector('[data-custom-continue]');
        customWrap?.classList.toggle('hidden', state.coffee_date_type !== 'custom');
        customContinue?.classList.toggle('hidden', state.coffee_date_type !== 'custom');
        if (state.coffee_date_type === 'surprise_me') {
          state.custom_coffee_type = '';
        }
        if (state.coffee_date_type === 'custom') {
          customWrap?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          showStep(3);
        }
        syncSummary();
      });
    });

    document.querySelector('[data-custom-done]')?.addEventListener('click', () => {
      showStep(3);
      syncSummary();
    });

    document.querySelectorAll('[data-date]').forEach((button) => {
      button.addEventListener('click', () => {
        state.my_selected_date = button.dataset.date;
        document.querySelector('[data-selected-date]').value = state.my_selected_date;
        showStep(4);
        syncSummary();
      });
    });

    const photoInput = document.querySelector('[data-photo-input]');
    const photoPreview = document.querySelector('[data-photo-preview]');
    photoInput?.addEventListener('change', () => {
      const [file] = photoInput.files || [];
      if (!file) {
        return;
      }
      const previewUrl = URL.createObjectURL(file);
      photoPreview.src = previewUrl;
      photoPreview.classList.remove('hidden');
      state.photo_url = previewUrl;
      showStep(5);
      syncSummary();
    });

    document.querySelector('[name="her_available_date"]')?.addEventListener('change', (event) => {
      state.her_available_date = event.target.value;
      syncSummary();
    });

    document.querySelector('[name="her_available_time"]')?.addEventListener('change', (event) => {
      state.her_available_time = event.target.value;
      syncSummary();
    });

    document.querySelector('[name="custom_coffee_type"]')?.addEventListener('input', (event) => {
      state.custom_coffee_type = event.target.value;
      syncSummary();
    });

    syncSummary();
  </script>
</MainLayout>
